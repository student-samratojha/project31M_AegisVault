<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Image Gallery</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body id="page-body" class="bg-gray-100 min-h-screen flex items-center justify-center transition-all duration-500">
    <!-- Theme Switcher -->
    <div class="fixed top-8 right-8 z-50">
        <button onclick="toggleThemeMenu()" class="bg-white/20 backdrop-blur-md p-3 rounded-full shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.172-1.172a4 4 0 115.656 5.656L11 17.657V7.343z" /></svg>
        </button>
        <div id="theme-menu" class="hidden absolute top-14 right-0 bg-white shadow-2xl rounded-xl p-4 w-48 border border-gray-200">
            <button onclick="setTheme('light')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium">Classic Blue</button>
            <button onclick="setTheme('monochrome')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium">Black & White</button>
            <button onclick="setTheme('inferno')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium">Red & Black</button>
            <button onclick="setTheme('cyber')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium">Cyber Yellow</button>
        </div>
    </div>

    <div id="login-card" class="bg-white p-10 rounded-3xl shadow-2xl w-full max-w-md border border-gray-100 transition-all duration-500">
        <div class="text-center mb-10">
            <h2 id="card-title" class="text-4xl font-black text-gray-800">Login</h2>
            <p class="text-gray-500 mt-2">Access your premium gallery</p>
        </div>
        <form action="/auth/login" method="POST">
            <div class="mb-4">
                <label class="block text-gray-700 text-sm font-bold mb-2">Email Address</label>
                <input type="email" name="email" required 
                    class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="mb-6">
                <label class="block text-gray-700 text-sm font-bold mb-2">Password</label>
                <input type="password" name="password" required 
                    class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <button type="submit" id="btn-submit"
                class="w-full bg-blue-600 text-white font-black py-4 rounded-2xl hover:scale-105 transition-all shadow-lg">
                Login
            </button>
        </form>
        <div class="mt-4 text-center">
            <p class="text-sm text-gray-600">
                Don't have an account? 
                <a href="/auth/register" class="text-blue-500 hover:underline">Register here</a> | <a href="/" class="text-blue-500 hover:underline">Home</a>
            </p>
        </div>
    </div>

    <script>
        function toggleThemeMenu() {
            document.getElementById('theme-menu').classList.toggle('hidden');
        }

        function setTheme(theme) {
            const body = document.getElementById('page-body');
            const card = document.getElementById('login-card');
            const title = document.getElementById('card-title');
            const btn = document.getElementById('btn-submit');

            body.className = 'min-h-screen flex items-center justify-center transition-all duration-500 ';
            card.className = 'p-10 rounded-3xl shadow-2xl w-full max-w-md border transition-all duration-500 ';

            if (theme === 'monochrome') {
                body.classList.add('bg-zinc-900');
                card.classList.add('bg-white', 'border-zinc-200');
                title.className = 'text-4xl font-black text-black';
                btn.className = 'w-full bg-black text-white font-black py-4 rounded-2xl transition-all shadow-lg';
            } else if (theme === 'inferno') {
                body.classList.add('bg-black');
                card.classList.add('bg-zinc-900', 'border-red-600');
                title.className = 'text-4xl font-black text-red-600';
                btn.className = 'w-full bg-red-600 text-white font-black py-4 rounded-2xl transition-all shadow-lg';
            } else if (theme === 'cyber') {
                body.classList.add('bg-black');
                card.classList.add('bg-zinc-900', 'border-yellow-400');
                title.className = 'text-4xl font-black text-yellow-400';
                btn.className = 'w-full bg-yellow-400 text-black font-black py-4 rounded-2xl transition-all shadow-lg';
            } else {
                body.classList.add('bg-gray-100');
                card.classList.add('bg-white', 'border-gray-100');
                title.className = 'text-4xl font-black text-gray-800';
                btn.className = 'w-full bg-blue-600 text-white font-black py-4 rounded-2xl transition-all shadow-lg';
            }
            localStorage.setItem('user-theme', theme);
            if(!document.getElementById('theme-menu').classList.contains('hidden')) toggleThemeMenu();
        }

        window.onload = () => {
            const savedTheme = localStorage.getItem('user-theme') || 'light';
            setTheme(savedTheme);
        };
    </script>
</body>
</html>