<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome - <%= user.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body id="page-body" class="bg-gray-100 min-h-screen transition-colors duration-500">
    <nav id="nav-bar" class="bg-white shadow-sm px-8 py-4 flex justify-between items-center transition-all duration-500">
        <h1 id="nav-logo" class="text-xl font-black text-slate-900 tracking-tighter">Aegis<span class="text-blue-600">Vault</span></h1>
        <div class="flex items-center space-x-6">
            <a href="/secure/edit/<%= user._id %>" id="nav-edit" class="text-sm font-semibold text-blue-500 hover:underline">Edit Profile</a>
            <a href="/auth/logout" class="text-gray-600 hover:text-red-600 font-medium">Logout</a>
        </div>
    </nav>

    <!-- Theme Switcher -->
    <div class="fixed bottom-8 right-8 z-50">
        <button onclick="toggleThemeMenu()" class="bg-indigo-600 text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.172-1.172a4 4 0 115.656 5.656L11 17.657V7.343z" /></svg>
        </button>
        <div id="theme-menu" class="hidden absolute bottom-20 right-0 bg-white shadow-2xl rounded-xl p-4 w-48 border border-gray-200">
            <button onclick="setTheme('light')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium text-blue-600">Classic Blue</button>
            <button onclick="setTheme('monochrome')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium text-black">Black & White</button>
            <button onclick="setTheme('inferno')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium text-red-600">Red & Black</button>
            <button onclick="setTheme('cyber')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium text-yellow-500">Cyber Yellow</button>
        </div>
    </div>

    <main class="max-w-4xl mx-auto mt-12 p-6">
        <div id="profile-card" class="bg-white rounded-2xl shadow-xl overflow-hidden transition-all duration-500">
            <div id="card-header" class="bg-blue-600 h-32 transition-all duration-500"></div>
            <div class="px-8 pb-8">
                <div class="relative -top-12 flex items-end space-x-6">
                    <div class="h-32 w-32 bg-gray-300 rounded-3xl border-4 border-white shadow-xl flex items-center justify-center text-3xl font-bold text-gray-600 overflow-hidden">
                        <% if (user.profilePic) { %>
                            <img src="/<%= user.profilePic.replace(/\\/g, '/') %>" class="h-full w-full object-cover">
                        <% } else { %>
                            <%= user.name.charAt(0) %>
                        <% } %>
                    </div>
                    <div class="pb-2">
                        <h2 id="card-name" class="text-3xl font-bold text-gray-800"><%= user.name %></h2>
                        <p class="text-gray-500"><%= user.email %></p>
                    </div>
                </div>

                <!-- User Info Bio Section -->
                <div class="mb-8">
                    <p id="card-bio" class="text-gray-600 italic leading-relaxed max-w-2xl">
                        <%= user.bio || "No bio added yet. Click 'Edit Profile' to share something about yourself." %>
                    </p>
                </div>

                <!-- Info Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                    <div id="box-loc" class="bg-gray-50 p-4 rounded-2xl border border-gray-100 transition-all duration-500">
                        <span class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Location</span>
                        <span class="font-bold text-gray-800"><%= user.city || 'N/A' %>, <%= user.country || 'N/A' %></span>
                    </div>
                    <div id="box-joined" class="bg-gray-50 p-4 rounded-2xl border border-gray-100 transition-all duration-500">
                        <span class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Member Since</span>
                        <span class="font-bold text-gray-800"><%= new Date(user.createdAt).toLocaleDateString() %></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <a href="/image/upload" id="upload-box" class="group block p-6 border-2 border-blue-50 rounded-xl hover:border-blue-500 transition">
                        <h3 id="upload-text" class="text-xl font-bold text-blue-600 group-hover:underline">Deposit to Vault →</h3>
                        <p id="upload-subtext" class="text-gray-600 mt-2">Securely upload new files to your private space.</p>
                    </a>
                    <div id="status-box" class="p-6 bg-gray-50 rounded-xl transition-all duration-500">
                        <h3 id="status-text" class="text-lg font-bold text-gray-700">Account Status</h3>
                        <p class="text-green-600 font-medium mt-2">Active Member</p>
                    </div>
                </div>

                <h3 id="gallery-title" class="text-xl font-bold mt-12 mb-6">My Recent Uploads</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <% docs.forEach(doc => { %>
                        <div id="img-card-<%= doc._id %>" class="border rounded-xl overflow-hidden bg-white shadow-sm transition-all duration-500">
                            <img src="/<%= doc.imageUrl.startsWith('data:') ? doc.imageUrl : doc.imageUrl.replace(/\\/g, '/') %>" class="w-full h-40 object-cover">
                            <div class="p-4 flex justify-between items-center bg-inherit">
                                <span class="font-bold text-sm text-gray-800"><%= doc.title %></span>
                                <form action="/image/delete" method="POST" onsubmit="return confirm('Are you sure?')">
                                    <input type="hidden" name="id" value="<%= doc._id %>">
                                    <button class="text-red-500 text-xs font-bold hover:underline">Remove</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                    <% if (docs.length === 0) { %>
                        <p class="text-gray-400 italic text-sm">Your gallery is empty.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script>
        function toggleThemeMenu() { document.getElementById('theme-menu').classList.toggle('hidden'); }
        function setTheme(theme) {
            const body = document.getElementById('page-body');
            const nav = document.getElementById('nav-bar');
            const card = document.getElementById('profile-card');
            const header = document.getElementById('card-header');
            const boxes = [document.getElementById('upload-box'), document.getElementById('status-box')];
            const textElements = [document.getElementById('card-name'), document.getElementById('gallery-title'), document.getElementById('nav-logo')];

            body.className = 'min-h-screen transition-all duration-500 ';
            card.className = 'rounded-2xl shadow-xl overflow-hidden transition-all duration-500 ';
            nav.className = 'shadow-sm px-8 py-4 flex justify-between items-center transition-all duration-500 ';
            header.className = 'h-32 transition-all duration-500 ';

            if (theme === 'monochrome') {
                body.classList.add('bg-zinc-900'); card.classList.add('bg-white');
                nav.classList.add('bg-black', 'text-white'); header.classList.add('bg-black');
                boxes.forEach(b => b.className = 'p-6 bg-zinc-50 border border-zinc-200 rounded-xl');
                textElements.forEach(t => t.style.color = 'black');
            } else if (theme === 'inferno') {
                body.classList.add('bg-black'); card.classList.add('bg-zinc-900', 'border', 'border-red-600');
                nav.classList.add('bg-zinc-950', 'text-white', 'border-b', 'border-red-900'); header.classList.add('bg-red-900');
                boxes.forEach(b => b.className = 'p-6 bg-zinc-800 border border-red-900 rounded-xl text-white');
                textElements.forEach(t => t.style.color = 'white');
            } else if (theme === 'cyber') {
                body.classList.add('bg-black'); card.classList.add('bg-zinc-900', 'border-2', 'border-yellow-400');
                nav.classList.add('bg-black', 'text-yellow-400', 'border-b', 'border-yellow-400'); header.classList.add('bg-yellow-400');
                boxes.forEach(b => b.className = 'p-6 bg-black border border-yellow-400 rounded-xl text-yellow-400');
                textElements.forEach(t => t.style.color = '#facc15');
            } else {
                body.classList.add('bg-gray-100'); card.classList.add('bg-white');
                nav.classList.add('bg-white'); header.classList.add('bg-blue-600');
                boxes.forEach(b => b.className = 'p-6 bg-gray-50 border border-blue-50 rounded-xl');
                textElements.forEach(t => t.style.color = '');
            }
            localStorage.setItem('user-theme', theme);
            if(typeof toggleThemeMenu === 'function') toggleThemeMenu();
        }
        window.onload = () => { setTheme(localStorage.getItem('user-theme') || 'light'); };
    </script>
</body>
</html>