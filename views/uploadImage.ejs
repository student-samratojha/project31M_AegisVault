<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Image</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body id="page-body" class="bg-gray-100 min-h-screen flex items-center justify-center p-6 transition-all duration-500">
    <!-- Theme Switcher -->
    <div class="fixed top-8 right-8 z-50">
        <button onclick="toggleThemeMenu()" class="bg-white/20 backdrop-blur-md p-3 rounded-full shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.172-1.172a4 4 0 115.656 5.656L11 17.657V7.343z" /></svg>
        </button>
        <div id="theme-menu" class="hidden absolute top-14 right-0 bg-white shadow-2xl rounded-xl p-4 w-48 border border-gray-200">
            <button onclick="setTheme('light')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium">Classic Blue</button>
            <button onclick="setTheme('monochrome')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium">Black & White</button>
            <button onclick="setTheme('inferno')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium">Red & Black</button>
            <button onclick="setTheme('cyber')" class="w-full text-left px-3 py-2 hover:bg-gray-100 rounded text-sm font-medium">Cyber Yellow</button>
        </div>
    </div>

    <div id="upload-card" class="bg-white p-10 rounded-3xl shadow-2xl w-full max-w-lg border border-gray-100 transition-all duration-500">
        <h2 id="card-title" class="text-3xl font-black mb-8 text-blue-600 uppercase tracking-tighter text-center">Upload to Gallery</h2>
        <form action="/image/upload" method="POST" enctype="multipart/form-data" class="space-y-4">
            <div>
                <label id="label-1" class="block text-xs font-black uppercase text-gray-400 mb-2">Image Title</label>
                <input type="text" name="title" required class="w-full border-2 border-gray-100 p-4 rounded-2xl focus:outline-none transition-all">
            </div>
            <div>
                <label id="label-2" class="block text-xs font-black uppercase text-gray-400 mb-2">Description (Optional)</label>
                <textarea name="description" class="w-full border-2 border-gray-100 p-4 rounded-2xl h-24 focus:outline-none transition-all"></textarea>
            </div>
            <div>
                <label id="label-3" class="block text-xs font-black uppercase text-gray-400 mb-2">Select Image File</label>
                <input type="file" name="image" required class="w-full text-sm file:bg-blue-600 file:text-white file:py-3 file:px-6 file:rounded-xl file:border-0 file:font-bold hover:file:scale-105 transition-all">
            </div>
            <div class="pt-4 flex items-center justify-between">
                <a href="/secure/user" class="text-gray-400 font-bold hover:underline">Back</a>
                <button type="submit" id="btn-submit" class="bg-blue-600 text-white px-10 py-4 rounded-2xl font-black shadow-lg hover:scale-105 transition-all">
                    Upload Now
                </button>
            </div>
        </form>
    </div>

    <script>
        function toggleThemeMenu() { document.getElementById('theme-menu').classList.toggle('hidden'); }
        function setTheme(theme) {
            const body = document.getElementById('page-body');
            const card = document.getElementById('upload-card');
            const title = document.getElementById('card-title');
            const btn = document.getElementById('btn-submit');
            const labels = [document.getElementById('label-1'), document.getElementById('label-2'), document.getElementById('label-3')];

            body.className = 'min-h-screen flex items-center justify-center p-6 transition-all duration-500 ';
            card.className = 'p-10 rounded-3xl shadow-2xl w-full max-w-lg border transition-all duration-500 ';

            if (theme === 'monochrome') {
                body.classList.add('bg-zinc-900'); card.classList.add('bg-white', 'border-zinc-200');
                title.className = 'text-3xl font-black mb-8 text-black uppercase tracking-tighter text-center';
                btn.className = 'bg-black text-white px-10 py-4 rounded-2xl font-black shadow-lg hover:scale-105 transition-all';
                labels.forEach(l => l.className = 'block text-xs font-black uppercase text-zinc-400 mb-2');
            } else if (theme === 'inferno') {
                body.classList.add('bg-black'); card.classList.add('bg-zinc-900', 'border-red-600');
                title.className = 'text-3xl font-black mb-8 text-red-600 uppercase tracking-tighter text-center';
                btn.className = 'bg-red-600 text-white px-10 py-4 rounded-2xl font-black shadow-lg hover:scale-105 transition-all';
                labels.forEach(l => l.className = 'block text-xs font-black uppercase text-red-900 mb-2');
            } else if (theme === 'cyber') {
                body.classList.add('bg-black'); card.classList.add('bg-zinc-900', 'border-2', 'border-yellow-400');
                title.className = 'text-3xl font-black mb-8 text-yellow-400 uppercase tracking-tighter text-center';
                btn.className = 'bg-yellow-400 text-black px-10 py-4 rounded-2xl font-black shadow-lg hover:scale-105 transition-all';
                labels.forEach(l => l.className = 'block text-xs font-black uppercase text-yellow-600 mb-2');
            } else {
                body.classList.add('bg-gray-100'); card.classList.add('bg-white', 'border-gray-100');
                title.className = 'text-3xl font-black mb-8 text-blue-600 uppercase tracking-tighter text-center';
                btn.className = 'bg-blue-600 text-white px-10 py-4 rounded-2xl font-black shadow-lg hover:scale-105 transition-all';
                labels.forEach(l => l.className = 'block text-xs font-black uppercase text-gray-400 mb-2');
            }
            localStorage.setItem('user-theme', theme);
            if(!document.getElementById('theme-menu').classList.contains('hidden')) toggleThemeMenu();
        }
        window.onload = () => { setTheme(localStorage.getItem('user-theme') || 'light'); };
    </script>
</body>
</html>